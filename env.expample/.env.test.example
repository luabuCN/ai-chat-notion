# master 环境变量示例（复制为 .env.test，与 dev 的 .env 并存，两套容器可同时运行）
# 必填：AUTH_SECRET、POSTGRES_URL、REDIS_URL
# 修改 NEXT_PUBLIC_* / API_ORIGIN 后须重新构建 web 镜像

# --- 构建（可选）---
# COMPOSE_PARALLEL_LIMIT=1
# NODE_BUILD_HEAP_MB=2048
# NPM_REGISTRY=https://registry.npmmirror.com

# --- 宿主机端口（master 默认与 dev 错开）---
WEB_PORT=3000
SERVER_HTTP_PORT=5000

# --- 必填：认证与数据（可与 dev 共用库，或指向独立 test 库）---
AUTH_SECRET=replace-with-openssl-rand-base64-32
POSTGRES_URL=postgresql://user:password@postgres-host:5432/ai_chat_notion_test
REDIS_URL=redis://:password@redis-host:6379/1

# --- 公网 URL（端口须与 WEB_PORT / SERVER_HTTP_PORT 一致）---
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXTAUTH_URL=http://127.0.0.1:3000
API_ORIGIN=http://127.0.0.1:5000
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://127.0.0.1:5000/collab

# API 代理目标（docker 网络内部，一般不需要改）
# API_PROXY_URL=http://server:4000

AUTH_TRUST_HOST=true

# --- server 可选 ---
API_AUTH_SECRET=
SERVER_COLLAB_PATH=/collab
TZ=Asia/Shanghai

# --- 第三方与登录（可选）---
API_KEY=
MODELSCOPE_API_KEY=
UPLOADTHING_TOKEN=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
SMTP_USER=
SMTP_PASS=
