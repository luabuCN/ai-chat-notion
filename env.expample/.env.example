# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****
# Instructions to create an UploadThing account here: https://uploadthing.com/dashboard
# Get your API keys from: https://uploadthing.com/dashboard/settings
UPLOADTHING_SECRET=****
UPLOADTHING_APP_ID=****

# Instructions to create a PostgreSQL database here: https://vercel.com/docs/postgres
POSTGRES_URL=****

# Instructions to create a Redis store here:
# https://vercel.com/docs/redis
REDIS_URL=****

# Next.js 将 /api/* 代理到后端
# 本地 dev 默认 localhost:4000；Vercel 分离部署填 server 公网地址（与 server 项目 API_ORIGIN 一致）
# API_ORIGIN=https://your-server.vercel.app
# Docker 内网代理（compose 默认 http://server:4000，一般不必改）
# API_PROXY_URL=http://server:4000

# Collaborative editing server (Hocuspocus)
# Local: ws://localhost:4000/collab | Production: wss://your-domain.com/collab
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://localhost:4000/collab

# Firecrawl API key for saving web pages to knowledge base
# Get your key at: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=****

# Optional: override collab WebSocket path (default /collab)
# SERVER_COLLAB_PATH=/collab
AUTH_GITHUB_ID=...
AUTH_GITHUB_SECRET=...

# Email service (Nodemailer + 163 Mail)
# QQ 邮箱 SMTP 配置
SMTP_USER=your-qq-email@qq.com
SMTP_PASS=your-qq-auth-code  # 163 邮箱授权码，非登录密码
