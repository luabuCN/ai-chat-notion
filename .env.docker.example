# Docker Compose 环境变量模板
# 用法: docker compose --env-file .env.docker up -d --build
# 生产环境请替换所有占位符，勿提交真实密钥

# --- 数据库 ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_chat_notion
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PASSWORD=redis
REDIS_PORT=6379

# --- 服务端口 ---
WEB_PORT=3000
# Collaborative editing WebSocket (same host as API, path /collab)
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://localhost:4000/collab

# --- 认证 (必填) ---
# 生成: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 浏览器连接协同服务 (构建 Web 镜像时打入前端)
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://localhost:4000/collab

# --- GitHub OAuth (可选) ---
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- 邮箱登录 (可选) ---
SMTP_USER=
SMTP_PASS=

# --- AI 对话 (Moonshot，见 README) ---
API_KEY=

# --- AI 图片生成 (ModelScope，可选) ---
MODELSCOPE_API_KEY=

# --- OpenAI 兼容 API (可选) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- 文件上传 UploadThing (可选，见 README) ---
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=
