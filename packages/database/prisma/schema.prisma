generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String            @unique @db.VarChar(64)
  emailVerified      DateTime?         @db.Timestamp(6)
  password           String?           @db.VarChar(100)
  name               String?           @unique @db.VarChar(100)
  avatarUrl          String?
  currentWorkspaceId String?           @db.Uuid
  editorDocuments    EditorDocument[]
  imageGenerations   ImageGeneration[]
  ownedWorkspaces    Workspace[]       @relation("OwnedWorkspaces")
  memberships        WorkspaceMember[]
  accounts           Account[]
  sessions           Session[]
}

model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("Account")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamp(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamp(6)

  @@unique([identifier, token])
  @@map("VerificationToken")
}

// 邮箱验证码
model EmailVerificationCode {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @db.VarChar(100)
  code      String   @db.VarChar(6)
  expiresAt DateTime @db.Timestamp(6)
  createdAt DateTime @default(now()) @db.Timestamp(6)

  @@index([email])
  @@map("EmailVerificationCode")
}

// 空间模型
model Workspace {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(20)
  icon      String?  @db.VarChar(10)
  ownerId   String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  owner     User                @relation("OwnedWorkspaces", fields: [ownerId], references: [id], onDelete: Cascade)
  members   WorkspaceMember[]
  chats     Chat[]
  documents EditorDocument[]
  images    ImageGeneration[]
  invites   WorkspaceInvite[]

  inviteCode          String?   @unique @db.VarChar(64)
  inviteCodeCreatedAt DateTime? @db.Timestamp(6)

  @@index([ownerId])
  @@index([slug])
  @@index([inviteCode])
  @@map("Workspace")
}

// 图片生成记录
model ImageGeneration {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String    @db.Uuid
  workspaceId         String?   @db.Uuid
  workspaceRole       String    @default("member") @db.VarChar(20)
  workspacePermission String?   @db.VarChar(20)
  prompt              String    @db.Text
  negativePrompt      String?   @db.Text
  promptOptions       Json?
  model               String    @db.VarChar(100)
  aspectRatio         String?   @db.VarChar(20)
  size                String?   @db.VarChar(20)
  seed                Int?
  steps               Int?
  status              String    @default("PENDING") @db.VarChar(20)
  providerTaskId      String?   @unique @db.VarChar(100)
  providerStatus      String?   @db.VarChar(30)
  sourceImageUrl      String?
  outputImageUrl      String?
  outputFileKey       String?   @db.VarChar(255)
  errorMessage        String?   @db.Text
  createdAt           DateTime  @default(now()) @db.Timestamp(6)
  updatedAt           DateTime  @updatedAt @db.Timestamp(6)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("ImageGeneration")
}

// 空间成员关系
model WorkspaceMember {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @db.Uuid
  userId      String   @db.Uuid
  role        String   @default("member") @db.VarChar(20)
  permission  String   @default("view") @db.VarChar(20) // view, edit
  joinedAt    DateTime @default(now()) @db.Timestamp(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("WorkspaceMember")
}

// 空间邀请
model WorkspaceInvite {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @db.Uuid
  email       String?   @db.VarChar(100)
  role        String    @default("member") @db.VarChar(20)
  permission  String    @default("view") @db.VarChar(20)
  token       String    @unique @db.VarChar(64)
  expiresAt   DateTime  @db.Timestamp(6)
  acceptedAt  DateTime? @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([workspaceId])
  @@map("WorkspaceInvite")
}

model Chat {
  id          String   @id @default(uuid())
  createdAt   DateTime
  userId      String   @db.Uuid
  workspaceId String?  @db.Uuid
  title       String
  lastContext Json?

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Message_deprecated {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatId    String   @db.Uuid
  role      String   @db.VarChar
  content   Json     @db.Json
  createdAt DateTime @db.Timestamp(6)

  @@map("Message")
}

model Message {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatId      String   @db.Uuid
  role        String   @db.VarChar
  parts       Json     @db.Json
  attachments Json     @db.Json
  createdAt   DateTime @db.Timestamp(6)

  @@map("Message_v2")
}

model Vote_deprecated {
  chatId    String  @db.Uuid
  messageId String  @db.Uuid
  isUpvoted Boolean

  @@id([chatId, messageId], map: "Vote_chatId_messageId_pk")
  @@map("Vote")
}

model Vote {
  chatId    String  @db.Uuid
  messageId String  @db.Uuid
  isUpvoted Boolean

  @@id([chatId, messageId], map: "Vote_v2_chatId_messageId_pk")
  @@map("Vote_v2")
}

model Document {
  id        String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @db.Timestamp(6)
  title     String
  content   String?
  userId    String   @db.Uuid
  kind      String   @default("text") @map("text") @db.VarChar

  @@id([id, createdAt], map: "Document_id_createdAt_pk")
  @@map("Document")
}

model Suggestion {
  id                String   @id(map: "Suggestion_id_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId        String   @db.Uuid
  documentCreatedAt DateTime @db.Timestamp(6)
  originalText      String
  suggestedText     String
  description       String?
  isResolved        Boolean  @default(false)
  userId            String   @db.Uuid
  createdAt         DateTime @db.Timestamp(6)

  @@map("Suggestion")
}

model Stream {
  id        String   @id(map: "Stream_id_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatId    String   @db.Uuid
  createdAt DateTime @db.Timestamp(6)

  @@map("Stream")
}

model EditorDocument {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title              String
  content            String?   @default("")
  yjsState           Bytes?    // Yjs 协同编辑状态（二进制格式）
  userId             String    @db.Uuid
  workspaceId        String?   @db.Uuid
  parentDocumentId   String?   @db.Uuid
  icon               String?
  coverImage         String?
  coverImageType     String?   @default("url") @db.VarChar(10)
  coverImagePosition Int?      @default(50)
  isPublished        Boolean   @default(false)
  publicShareToken   String?   @unique @db.VarChar(64) // 公开分享链接 token
  isFavorite         Boolean   @default(false)
  deletedAt          DateTime? @db.Timestamp(6)
  createdAt          DateTime  @default(now()) @db.Timestamp(6)
  updatedAt          DateTime  @updatedAt @db.Timestamp(6)
  lastEditedBy       String?   @db.Uuid
  lastEditedByName   String?   @db.VarChar(100)
  /** 从 PDF 导入时保存的原始文件 URL（UploadThing 等），用于「下载原文档」 */
  sourcePdfUrl       String?
  /** 浏览器扩展等从网页剪藏时保存的原文 URL，用于标题栏标识与跳转原站 */
  sourcePageUrl      String?

  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace?             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentDocument EditorDocument?        @relation("DocumentHierarchy", fields: [parentDocumentId], references: [id], onDelete: Cascade)
  childDocuments EditorDocument[]       @relation("DocumentHierarchy")
  collaborators  DocumentCollaborator[] // 文档协作者
  visitors       DocumentVisitor[]      // 文档访问记录

  @@index([userId, deletedAt])
  @@index([parentDocumentId])
  @@index([workspaceId, deletedAt])
  @@index([publicShareToken])
  @@map("EditorDocument")
}

// 文档协作者（访客协作）
model DocumentCollaborator {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String    @db.Uuid
  email      String    @db.VarChar(100) // 被邀请者邮箱
  userId     String?   @db.Uuid         // 如果已注册则关联用户
  permission String    @default("edit") @db.VarChar(20) // view, edit
  status     String    @default("pending") @db.VarChar(20) // pending, accepted, rejected
  invitedBy  String    @db.Uuid         // 邀请人
  token      String    @unique @db.VarChar(64) // 邀请链接 token
  expiresAt  DateTime? @db.Timestamp(6) // 过期时间（可选）
  acceptedAt DateTime? @db.Timestamp(6)
  createdAt  DateTime  @default(now()) @db.Timestamp(6)

  document EditorDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, email])
  @@index([documentId])
  @@index([email])
  @@index([userId])
  @@index([token])
  @@map("DocumentCollaborator")
}

// 文档访问记录（用于记录用户访问过的公开文档）
model DocumentVisitor {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String   @db.Uuid
  userId     String   @db.Uuid
  visitedAt  DateTime @default(now()) @db.Timestamp(6)

  document EditorDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@index([userId])
  @@index([documentId])
  @@map("DocumentVisitor")
}
