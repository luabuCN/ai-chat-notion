{
  "name": "@repo/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./dist/client.js"
    },
    "./workspace-name": {
      "types": "./src/workspace-name.ts",
      "default": "./dist/workspace-name.js"
    },
    "./dicebear-avatar": {
      "types": "./src/dicebear-avatar.ts",
      "default": "./dist/dicebear-avatar.js"
    }
  },
  "scripts": {
    "build": "node ./scripts/prisma-generate.mjs && tsc -p tsconfig.build.json",
    "postinstall": "node ./scripts/prisma-generate.mjs",
    "generate": "node ./scripts/prisma-generate.mjs",
    "db:generate": "dotenv -e ../../.env.local -- node ./scripts/prisma-generate.mjs",
    "db:migrate": "dotenv -e ../../.env.local -- prisma migrate dev && node ./scripts/prisma-generate.mjs",
    "db:push": "dotenv -e ../../.env.local -- prisma db push --accept-data-loss",
    "db:pull": "dotenv -e ../../.env.local -- prisma db pull",
    "db:studio": "dotenv -e ../../.env.local -- prisma studio",
    "db:reset": "dotenv -e ../../.env.local -- prisma migrate reset",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ai": "6.0.37",
    "bcrypt-ts": "^5.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "pg": "^8.16.3",
    "tailwind-merge": "^2.5.2",
    "tokenlens": "1.3.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.6",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.4.5",
    "prisma": "^7.8.0",
    "typescript": "^5.6.3"
  },
  "turbo": {
    "extends": [
      "//"
    ],
    "tasks": {
      "build": {
        "outputs": [
          "dist/**",
          "src/generated/**"
        ]
      }
    }
  }
}
