{
  "name": "ai-chat-notion",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=@repo/web",
    "dev:collab": "turbo dev --filter=@repo/server",
    "dev:server": "turbo dev --filter=@repo/server",
    "dev:all": "turbo dev --filter=@repo/web --filter=@repo/server",
    "dev:extension": "turbo dev --filter=@repo/extensions",
    "build": "turbo build",
    "build:collab": "turbo build --filter=@repo/server",
    "build:server": "turbo build --filter=@repo/server",
    "lint": "turbo lint",
    "format": "turbo format",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.12.3",
  "pnpm": {
    "overrides": {
      "streamdown": "^2.5.0"
    }
  }
}
