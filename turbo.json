{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", ".output/**"],
      "env": [
        "NODE_ENV",
        "POSTGRES_URL",
        "AUTH_SECRET",
        "WEB_URL",
        "API_URL",
        "UPLOADTHING_TOKEN",
        "API_KEY",
        "MODELSCOPE_API_KEY",
        "AUTH_GITHUB_ID",
        "AUTH_GITHUB_SECRET",
        "SMTP_USER",
        "SMTP_PASS",
        "FIRECRAWL_API_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@repo/web#build": {
      "dependsOn": ["@repo/database#build", "@repo/ai#build"],
      "outputs": [".next/**"]
    },
    "@repo/web#dev": {
      "dependsOn": ["@repo/database#build", "@repo/ai#build"],
      "cache": false,
      "persistent": true
    },
    "@repo/database#build": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "@repo/server#dev": {
      "dependsOn": ["@repo/database#build", "@repo/ai#build"],
      "cache": false,
      "persistent": true,
      "env": [
        "POSTGRES_URL",
        "AUTH_SECRET",
        "JWT_SECRET",
        "API_AUTH_SECRET",
        "SERVER_HTTP_PORT",
        "SERVER_COLLAB_PATH",
        "REDIS_URL",
        "API_KEY",
        "MODELSCOPE_API_KEY",
        "WEB_URL",
        "API_URL"
      ]
    },
    "@repo/server#build": {
      "dependsOn": ["@repo/database#build", "@repo/ai#build"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV", "POSTGRES_URL", "AUTH_SECRET"]
    },
    "migrate:yjs": {
      "cache": false,
      "env": ["POSTGRES_URL"]
    }
  }
}
