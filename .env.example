# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****
# Instructions to create an UploadThing account here: https://uploadthing.com/dashboard
# Get your API keys from: https://uploadthing.com/dashboard/settings
UPLOADTHING_SECRET=****
UPLOADTHING_APP_ID=****

# Instructions to create a PostgreSQL database here: https://vercel.com/docs/postgres
POSTGRES_URL=****

# Instructions to create a Redis store here:
# https://vercel.com/docs/redis
REDIS_URL=****

# Collaborative editing server (Hocuspocus)
# Local: ws://localhost:1234 | Production: wss://your-domain.com/collab
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://localhost:1234

COLLAB_SERVER_PORT=***
AUTH_GITHUB_ID=...
AUTH_GITHUB_SECRET=...

# Email service (Nodemailer + QQ Mail)
# QQ 邮箱 SMTP 配置
SMTP_USER=your-qq-email@qq.com
SMTP_PASS=your-qq-auth-code  # QQ 邮箱授权码，非登录密码
