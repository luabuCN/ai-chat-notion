# 服务器本地构建部署 — 环境变量示例（粘贴到 Dokploy → Environment，会生成 .env 供 compose 替换）
# 必填：AUTH_SECRET、POSTGRES_URL、REDIS_URL
# 上域名后务必覆盖「公网 URL」一节并重新 Deploy（重新构建 web 镜像）

# --- 构建（可选）---
# 海外 VPS 默认可省略（使用 registry.npmjs.org）；国内构建机可设：
# NPM_REGISTRY=https://registry.npmmirror.com
# 内存 ≤4GB 时强烈建议开启，避免 web/server 并行构建 OOM：
# COMPOSE_PARALLEL_LIMIT=1
# Next.js 构建 Node 堆上限（MB）；默认 2048，仍 OOM 可试 2560（3GB 机器必须先加 swap）
# NODE_BUILD_HEAP_MB=2048

# --- GitHub Actions SSH 自动部署（可选）---
# 在 GitHub → Settings → Secrets and variables → Actions 配置：
#   Secrets: SSH_HOST, SSH_PASSWORD
#   Secrets（可选）: SSH_USER（默认 root）, SSH_PORT（默认 22）
#   Variables（可选）: DEPLOY_PATH（默认 /opt/ai-chat-notion）
# 服务器一次性准备：
#   git clone git@github.com:<owner>/ai-chat-notion.git /opt/ai-chat-notion
#   cp dokploy.env.example .env 并填写 AUTH_SECRET / POSTGRES_URL / REDIS_URL 等
#   为服务器配置 Deploy Key（只读）以便 git pull
# push 到 main / master / dev / docker-local 分支后自动 SSH 部署并清理悬空镜像

# --- 宿主机端口（可选）---
WEB_PORT=8080
SERVER_HTTP_PORT=4000

# --- 必填：认证与数据 ---
AUTH_SECRET=replace-with-openssl-rand-base64-32
POSTGRES_URL=postgresql://user:password@postgres-host:5432/ai_chat_notion
REDIS_URL=redis://:password@redis-host:6379

# --- 公网 URL（本地默认可省略；绑定域名后改为 https/wss）---
# web 对外地址；server 的 WEB_ORIGIN 也来自此变量
# 注意：修改 NEXT_PUBLIC_* 变量后需要重新构建 web 镜像才能生效
NEXT_PUBLIC_APP_URL=http://127.0.0.1:8080
NEXTAUTH_URL=http://127.0.0.1:8080
# API 对外地址；web/server 的 NEXT_PUBLIC_API_ORIGIN 均来自此变量
API_ORIGIN=http://127.0.0.1:4000
# 协同 WebSocket；路径需与 SERVER_COLLAB_PATH 一致
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://127.0.0.1:4000/collab

# API 代理目标（docker 网络内部地址，一般不需要改）
# API_PROXY_URL=http://server:4000

AUTH_TRUST_HOST=true

# --- server 可选 ---
API_AUTH_SECRET=
SERVER_COLLAB_PATH=/collab
TZ=Asia/Shanghai

# --- 第三方与登录（可选）---
API_KEY=
MODELSCOPE_API_KEY=
UPLOADTHING_TOKEN=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
SMTP_USER=
SMTP_PASS=
# Dokploy Environment 示例（粘贴到 Dokploy → Environment，会生成 .env 供 compose 替换）
# 必填：AUTH_SECRET、POSTGRES_URL、REDIS_URL
# 上域名后务必覆盖「公网 URL」一节并重新 Deploy

# --- 镜像与宿主机端口（可选）---
# GHCR 用户名（小写），须与 GitHub 账号一致；Actions 用 GITHUB_REPOSITORY_OWNER 推送
GHCR_OWNER=luabucn
# 与 Actions 推送的分支标签一致：dev 环境用 dev，master 用 master（不要用 latest）
IMAGE_TAG=dev
WEB_PORT=8080
SERVER_HTTP_PORT=4000

# --- 必填：认证与数据 ---
AUTH_SECRET=replace-with-openssl-rand-base64-32
POSTGRES_URL=postgresql://user:password@postgres-host:5432/ai_chat_notion
REDIS_URL=redis://:password@redis-host:6379

# --- 公网 URL（本地默认可省略；绑定域名后改为 https/wss）---
# web 对外地址；server 的 WEB_ORIGIN 也来自此变量
NEXT_PUBLIC_APP_URL=http://127.0.0.1:8080
NEXTAUTH_URL=http://127.0.0.1:8080
# API 对外地址；web/server 的 NEXT_PUBLIC_API_ORIGIN 均来自此变量
API_ORIGIN=http://127.0.0.1:4000
# 协同 WebSocket；路径需与 SERVER_COLLAB_PATH 一致
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://127.0.0.1:4000/collab

AUTH_TRUST_HOST=true

# --- server 可选 ---
API_AUTH_SECRET=
SERVER_COLLAB_PATH=/collab
TZ=Asia/Shanghai

# --- 第三方与登录（可选）---
API_KEY=
MODELSCOPE_API_KEY=
UPLOADTHING_TOKEN=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
SMTP_USER=
SMTP_PASS=
