# =============================================================================
# Dokploy Compose 部署（方案 A：web + server 同一 stack）
# =============================================================================
#
# 1. Dokploy → 新建应用 → 类型选 **Compose**
# 2. 关联 GitHub 仓库，Compose 文件路径填：docker-compose.yml
# 3. 把本文件内容粘贴到 Dokploy → Environment
# 4. 删除之前单独部署的 web / server 应用（避免端口冲突、网络不通）
# 5. GitHub 仓库 Settings → Variables 同步设置 API_ORIGIN（供 Actions 构建 web 镜像时写入客户端）
# 6. Deploy；浏览器通过 API_ORIGIN 直连后端 :4000
#
# 域名（Dokploy → Domains）：
#   - web  → 容器端口 8080（主站）
#   - server → 容器端口 4000（API / 协同 WebSocket，可选绑域名）
#
# 镜像标签 IMAGE_TAG 须与 GitHub Actions 推送分支一致（dev 分支用 dev）
# =============================================================================

# --- 公网 URL（只需 3 项）---
NEXT_PUBLIC_APP_URL=http://156.239.235.110:8080
API_ORIGIN=http://156.239.235.110:4000
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://156.239.235.110:4000/collab

# --- 镜像与宿主机端口 ---
GHCR_OWNER=luabucn
IMAGE_TAG=dev
WEB_PORT=8080
SERVER_HTTP_PORT=4000

# --- 必填：认证与数据 ---
AUTH_SECRET=replace-with-openssl-rand-base64-32
POSTGRES_URL=postgresql://user:password@postgres-host:5432/ai_chat_notion
REDIS_URL=redis://:password@redis-host:6379

AUTH_TRUST_HOST=true

# --- 可选 ---
API_AUTH_SECRET=
SERVER_COLLAB_PATH=/collab
TZ=Asia/Shanghai
API_KEY=
MODELSCOPE_API_KEY=
UPLOADTHING_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
SMTP_USER=
SMTP_PASS=

# 勿单独配置 NEXTAUTH_URL（默认等于 NEXT_PUBLIC_APP_URL）
