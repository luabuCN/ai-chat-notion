# Dokploy Environment 示例（粘贴到 Dokploy → Environment）
# 公网部署只需配置下面 3 项 URL（其余见文件底部可选/必填）

# 1. 主站地址（web 容器，端口 8080）
NEXT_PUBLIC_APP_URL=http://127.0.0.1:8080

# 2. 后端 API 地址（server 容器，端口 4000；供 CORS、扩展、WebSocket 等直连）
API_ORIGIN=http://127.0.0.1:4000

# 3. 协同编辑 WebSocket（路径需与 SERVER_COLLAB_PATH 一致，默认 /collab）
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://127.0.0.1:4000/collab

# --- 镜像与宿主机端口（可选）---
GHCR_OWNER=luabucn
IMAGE_TAG=dev
WEB_PORT=8080
SERVER_HTTP_PORT=4000

# --- 必填：认证与数据 ---
AUTH_SECRET=replace-with-openssl-rand-base64-32
POSTGRES_URL=postgresql://user:password@postgres-host:5432/ai_chat_notion
REDIS_URL=redis://:password@redis-host:6379

AUTH_TRUST_HOST=true

# --- server 可选 ---
API_AUTH_SECRET=
SERVER_COLLAB_PATH=/collab
TZ=Asia/Shanghai

# --- 第三方与登录（可选）---
API_KEY=
MODELSCOPE_API_KEY=
UPLOADTHING_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
SMTP_USER=
SMTP_PASS=
