# 复制到 Dokploy → Compose 应用 → Environment 编辑器（一行一个 KEY=value）
# 详见 docs/dokploy.md
#
# 前端/API 地址未填写时，compose 默认：
#   http://127.0.0.1:3000  (web)
#   http://127.0.0.1:4000  (server / API)
#   ws://127.0.0.1:4000/collab  (协同)

AUTH_SECRET=replace-with-openssl-rand-base64-32

POSTGRES_URL=postgresql://user:password@postgres-host:5432/ai_chat_notion
REDIS_URL=redis://:password@redis-host:6379

AUTH_TRUST_HOST=true

API_KEY=
MODELSCOPE_API_KEY=
UPLOADTHING_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
SMTP_USER=
SMTP_PASS=
